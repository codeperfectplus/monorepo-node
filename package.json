{
  "name": "my-monorepo",
  "version": "1.0.0",
  "description": "NestJS + Next.js npm workspaces monorepo",
  "main": "index.js",
  "scripts": {
    "dev": "npm run db:generate && turbo dev",
    "dev:api": "turbo dev --filter=api",
    "dev:web": "turbo dev --filter=web",
    "build": "turbo build",
    "build:api": "turbo build --filter=api",
    "build:web": "turbo build --filter=web",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "check": "npm run lint && npm run typecheck && npm run test",
    "db:generate": "npm run db:generate --workspace=@shared/database",
    "db:migrate:dev": "npm run db:migrate:dev --workspace=@shared/database",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace=@shared/database",
    "db:push": "npm run db:push --workspace=@shared/database",
    "db:studio": "npm run db:studio --workspace=@shared/database",
    "db:format": "npm run db:format --workspace=@shared/database",
    "db:validate": "npm run db:validate --workspace=@shared/database",
    "db:up": "docker start postgres",
    "db:down": "docker stop postgres",
    "docker:up": "docker-compose up -d"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "private": true,
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.9.6"
  },
  "dependencies": {}
}
