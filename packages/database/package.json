{
  "name": "@shared/database",
  "version": "1.0.0",
  "description": "Prisma schema and migration workspace",
  "private": true,
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- prisma generate --schema=prisma/schema.prisma",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy --schema=prisma/schema.prisma",
    "db:push": "dotenv -e ../../.env -- prisma db push --schema=prisma/schema.prisma",
    "db:studio": "dotenv -e ../../.env -- prisma studio --schema=prisma/schema.prisma",
    "db:format": "dotenv -e ../../.env -- prisma format --schema=prisma/schema.prisma",
    "db:validate": "dotenv -e ../../.env -- prisma validate --schema=prisma/schema.prisma"
  },
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.4.2",
    "pg": "^8.16.0",
    "prisma": "^7.7.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}