{
  "name": "@shared/database",
  "version": "1.0.0",
  "description": "Prisma schema and migration workspace",
  "private": true,
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "scripts": {
    "db:generate": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ./node_modules/.bin/prisma generate --schema=prisma/schema.prisma",
    "db:migrate:dev": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ./node_modules/.bin/prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:deploy": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ./node_modules/.bin/prisma migrate deploy --schema=prisma/schema.prisma",
    "db:push": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ./node_modules/.bin/prisma db push --schema=prisma/schema.prisma",
    "db:studio": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ./node_modules/.bin/prisma studio --schema=prisma/schema.prisma",
    "db:format": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ./node_modules/.bin/prisma format --schema=prisma/schema.prisma",
    "db:validate": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ./node_modules/.bin/prisma validate --schema=prisma/schema.prisma"
  },
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "dotenv": "^16.6.1",
    "prisma": "^6.16.2"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
